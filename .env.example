ANTHROPIC_API_KEY=sk-ant-...
# Chat model id. Defaults to claude-sonnet-4-5 if unset. Override to pin a
# snapshot or use a cheaper model. The old claude-sonnet-4-20250514 is retired.
MODEL=claude-sonnet-4-5
DATA_SOURCE=mock
FHIR_BASE_URL=https://localhost:9300/apis/default/fhir
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_USERNAME=admin
FHIR_PASSWORD=pass
FHIR_SCOPE=openid api:fhir user/Patient.read user/AllergyIntolerance.read user/MedicationRequest.read user/Observation.read user/Condition.read
OPENEMR_ORIGINS=
# Comma-separated CORS origins allowed to call the API (in addition to same-origin).
ALLOWED_ORIGINS=
# NODE_TLS_REJECT_UNAUTHORIZED=1  # Uncomment for dev: allow self-signed certs (OpenEMR Docker)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
PORT=3000
